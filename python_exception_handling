#mini project
def process_purchase():
    filename = input("Enter the file name: ")
    try:
        with open(filename, 'r') as file:
            lines = file.readlines()
        
        items_count = 0
        free_items = 0
        total_amount = 0
        discount = 0
        
        for line in lines:
            parts = line.split()
            if not parts:
                continue
            
            if parts[0].lower() == 'discount':
                discount = int(parts[1])
            else:
                items_count += 1
                price_str = parts[1]
                if price_str.lower() == 'free':
                    free_items += 1
                else:
                    total_amount += int(price_str)
        
        print(f"No of items purchased: {items_count}")
        print(f"No of free items: {free_items}")
        print(f"Amount to pay: {total_amount}")
        print(f"Discount given: {discount}")
        print(f"Final amount paid: {total_amount - discount}")

    except FileNotFoundError:
        print("Error: The file was not found.")
    except ValueError:
        print("Error: Invalid data format in the file.")
    except Exception as e:
        print(f"An error occurred: {e}")

if __name__ == "__main__":
    process_purchase()


