import sys

def calculate_happiness():
    args = sys.argv[1:]
    
    set1 = set(args[0].split('-'))
    set2 = set(args[1].split('-'))
    numbers = args[2].split('-')
    
    happiness = 0
    for num in numbers:
        if num in set1:
            happiness += 1
        elif num in set2:
            happiness -= 1
            
    print(happiness)

if __name__ == "__main__":
    calculate_happiness()

