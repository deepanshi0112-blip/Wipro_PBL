import sys

def is_prime(n):
    if n <= 1:
        return False
    for i in range(2, int(n**0.5) + 1):
        if n % i == 0:
            return False
    return True

args = sys.argv[1:]
prime_sum = 0

for i in range(10):
    num = int(args[i])
    if is_prime(num):
        prime_sum += num

print(prime_sum)
