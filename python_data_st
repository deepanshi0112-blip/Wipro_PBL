people_facts = {
    "Jeff": "Is afraid of Dogs.",
    "David": "Plays the piano.",
    "Jason": "Can fly an airplane."
}

def display_facts(data):
    for name, fact in data.items():
        print(f"{name}: {fact}")

print("--- Initial List ---")
display_facts(people_facts)

