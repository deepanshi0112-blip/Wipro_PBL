# 4. If the first or last character is 'x', return string without them.
def remove_x(input_string):
    if input_string.startswith('x'):
        input_string = input_string[1:]
    if input_string.endswith('x'):
        input_string = input_string[:-1]
    return input_string

print("Result after removing 'x':", remove_x("xHix"))

# 5. Return a string made of n repetitions of the last n characters.
def repeat_last_n(input_string, n):
    last_n_chars = input_string[-n:]
    return last_n_chars * n

print("Result of repetitions:", repeat_last_n("Wipro", 3))
